{
  "mcpServers": {
    "Unleash": {
      "command": "npx",
      "args": [
        "-y",
        "@unleash/mcp@latest",
        "--log-level",
        "error"
      ],
      "env": {
        "UNLEASH_BASE_URL": "https://unleash.letterfest.com",
        "UNLEASH_DEFAULT_PROJECT": "default"
      },
      "envFile": "${userHome}/.unleash/mcp.env"
    }
  }
}
